{
  "rewrites": [
    {
      "source": "/news/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(?:kakaotalk-scrap|facebookexternalhit|Twitterbot|Slackbot|LinkedInBot|Discordbot|TelegramBot|WhatsApp|Googlebot|Yeti|Applebot|bingbot).*"
        }
      ],
      "destination": "/api/og?id=:id"
    },
    {
      "source": "/((?!api|assets|favicon|og-image).*)",
      "destination": "/index.html"
    }
  ]
}
